{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Messaging Brief",
  "type": "object",
  "required": [
    "brief_id",
    "company_id",
    "audience_label",
    "headline",
    "subheadline",
    "proof_points",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "brief_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "offer_id": {"type": "string"},
    "audience_label": {"type": "string"},
    "headline": {"type": "string"},
    "subheadline": {"type": "string"},
    "proof_points": {"type": "array", "items": {"type": "string"}},
    "objection_handlers": {"type": "array", "items": {"type": "string"}},
    "forbidden_phrases": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
