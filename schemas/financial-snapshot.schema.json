{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Financial Snapshot",
  "type": "object",
  "required": [
    "snapshot_id",
    "company_id",
    "currency_code",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "assumption_refs",
    "finding_refs",
    "validated_fact_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "snapshot_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "currency_code": {"type": "string", "enum": ["MXN", "USD"]},
    "customer_lifetime_months": {"type": "number"},
    "average_monthly_revenue_per_customer": {"type": "number"},
    "gross_margin_ratio": {"type": "number"},
    "estimated_cac": {"type": "number"},
    "estimated_ltv": {"type": "number"},
    "ltv_cac_ratio": {"type": "number"},
    "payback_months": {"type": "number"},
    "break_even_customers": {"type": "number"},
    "viability_warning": {"type": "string"},
    "status": {"type": "string", "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "assumption_refs": {"type": "array", "items": {"type": "string"}},
    "finding_refs": {"type": "array", "items": {"type": "string"}},
    "validated_fact_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
