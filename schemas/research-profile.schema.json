{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Profile",
  "type": "object",
  "required": [
    "profile_id",
    "company_id",
    "intake_mode",
    "seed_summary",
    "research_stage",
    "primary_goal",
    "currency_code",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "readiness_score",
    "open_questions_count",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "profile_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "intake_mode": {"type": "string", "enum": ["idea", "existing"]},
    "seed_summary": {"type": "string"},
    "primary_goal": {"type": "string"},
    "website": {"type": "string"},
    "geography_focus": {"type": "array", "items": {"type": "string"}},
    "currency_code": {"type": "string", "enum": ["MXN", "USD"]},
    "workspace_mode": {"type": "string", "enum": ["clean_bootstrap", "in_place_business_folder"]},
    "competitors": {"type": "array", "items": {"type": "string"}},
    "available_sources": {"type": "array", "items": {"type": "string"}},
    "known_constraints": {"type": "array", "items": {"type": "string"}},
    "existing_material_summary": {"type": "string"},
    "existing_file_manifest": {"type": "array", "items": {"type": "string"}},
    "open_assumptions": {"type": "array", "items": {"type": "string"}},
    "research_stage": {
      "type": "string",
      "enum": ["seeded", "collecting_evidence", "analyzing", "needs_validation", "decision_ready", "planning", "stale"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "readiness_score": {"type": "number", "minimum": 0, "maximum": 1},
    "open_questions_count": {"type": "integer"},
    "next_step": {"type": "string"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
