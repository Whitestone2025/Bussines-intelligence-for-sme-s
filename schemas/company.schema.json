{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Company",
  "type": "object",
  "required": [
    "company_id",
    "name",
    "business_mode",
    "primary_country",
    "currency_code",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 1},
    "legal_name": {"type": "string"},
    "business_mode": {"type": "string", "enum": ["idea", "existing"]},
    "primary_country": {"type": "string", "enum": ["MX"]},
    "primary_region": {"type": "string"},
    "primary_city": {"type": "string"},
    "currency_code": {"type": "string", "enum": ["MXN", "USD"]},
    "industry": {"type": "string"},
    "sector_tags": {"type": "array", "items": {"type": "string"}},
    "website": {"type": "string"},
    "seed_summary": {"type": "string"},
    "current_state_summary": {"type": "string"},
    "known_constraints": {"type": "array", "items": {"type": "string"}},
    "tone_constraints": {"type": "array", "items": {"type": "string"}},
    "forbidden_phrases": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
