{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Entry",
  "type": "object",
  "required": [
    "evidence_id",
    "company_id",
    "source_id",
    "evidence_type",
    "title",
    "summary",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "source_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "service_id": {"type": "string"},
    "icp_id": {"type": "string"},
    "channel_id": {"type": "string"},
    "evidence_type": {"type": "string", "enum": ["quote", "observation", "metric", "claim", "artifact"]},
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "quotes": {"type": "array", "items": {"type": "string"}},
    "observations": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "capture_date": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
