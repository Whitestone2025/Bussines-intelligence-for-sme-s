{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Competitor",
  "type": "object",
  "required": [
    "competitor_id",
    "company_id",
    "name",
    "competitor_type",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "assumption_refs",
    "finding_refs",
    "validated_fact_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "competitor_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type": "string"},
    "website": {"type": "string"},
    "competitor_type": {"type": "string", "enum": ["direct", "indirect", "substitute"]},
    "geography": {"type": "array", "items": {"type": "string"}},
    "positioning_summary": {"type": "string"},
    "pricing_summary": {"type": "string"},
    "channels": {"type": "array", "items": {"type": "string"}},
    "strengths": {"type": "array", "items": {"type": "string"}},
    "weaknesses": {"type": "array", "items": {"type": "string"}},
    "trust_signals": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "assumption_refs": {"type": "array", "items": {"type": "string"}},
    "finding_refs": {"type": "array", "items": {"type": "string"}},
    "validated_fact_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
