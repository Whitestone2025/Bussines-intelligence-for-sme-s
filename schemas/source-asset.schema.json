{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Asset",
  "type": "object",
  "required": [
    "source_id",
    "company_id",
    "source_kind",
    "title",
    "status",
    "source_origin",
    "source_refs",
    "evidence_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "source_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "source_kind": {"type": "string"},
    "origin": {"type": "string"},
    "title": {"type": "string"},
    "uri_or_path": {"type": "string"},
    "status": {"type": "string", "enum": ["captured", "processed", "normalized", "stale", "rejected"]},
    "source_origin": {"type": "string"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "body": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
