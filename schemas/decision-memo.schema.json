{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Memo",
  "type": "object",
  "required": [
    "decision_id",
    "company_id",
    "decision_type",
    "recommended_action",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "assumption_refs",
    "finding_refs",
    "validated_fact_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "decision_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "decision_type": {"type": "string", "enum": ["go_to_market", "pricing", "market_selection", "offer", "channel", "viability"]},
    "recommended_action": {"type": "string"},
    "decision_summary": {"type": "string"},
    "why_now": {"type": "string"},
    "alternative_actions": {"type": "array", "items": {"type": "string"}},
    "key_risks": {"type": "array", "items": {"type": "string"}},
    "next_steps": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "assumption_refs": {"type": "array", "items": {"type": "string"}},
    "finding_refs": {"type": "array", "items": {"type": "string"}},
    "validated_fact_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
