{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Plan",
  "type": "object",
  "required": [
    "plan_id",
    "company_id",
    "plan_horizon",
    "initiative_roadmap",
    "decision_checkpoints",
    "no_regret_moves",
    "strategic_alternatives",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "decision_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "plan_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "plan_horizon": {"type": "string", "enum": ["30-60-90", "90-day", "launch", "turnaround"]},
    "objective": {"type": "string"},
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["milestone_id", "name", "timeframe", "success_metric"],
        "properties": {
          "milestone_id": {"type": "string"},
          "name": {"type": "string"},
          "timeframe": {"type": "string"},
          "owner": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "success_metric": {"type": "string"}
        }
      }
    },
    "initiative_roadmap": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["initiative_id", "name", "workstream", "objective", "owner", "timeframe", "dependencies", "leading_indicator", "lagging_indicator", "success_metric", "stage_gate", "stage_gate_question", "key_risks", "risk_mitigation", "decision_trigger", "exit_criteria"],
        "properties": {
          "initiative_id": {"type": "string"},
          "name": {"type": "string"},
          "workstream": {"type": "string"},
          "objective": {"type": "string"},
          "owner": {"type": "string"},
          "timeframe": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "leading_indicator": {"type": "string"},
          "lagging_indicator": {"type": "string"},
          "success_metric": {"type": "string"},
          "stage_gate": {"type": "string"},
          "stage_gate_question": {"type": "string"},
          "key_risks": {"type": "array", "items": {"type": "string"}},
          "risk_mitigation": {"type": "array", "items": {"type": "string"}},
          "decision_trigger": {"type": "string"},
          "exit_criteria": {"type": "string"}
        }
      }
    },
    "decision_checkpoints": {"type": "array", "items": {"type": "string"}},
    "no_regret_moves": {"type": "array", "items": {"type": "string"}},
    "strategic_alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alternative_id", "label", "thesis", "route_type", "why_this_route", "criteria_fit", "key_bets", "key_risks", "what_must_be_true", "recommended"],
        "properties": {
          "alternative_id": {"type": "string"},
          "label": {"type": "string"},
          "thesis": {"type": "string"},
          "route_type": {"type": "string"},
          "why_this_route": {"type": "string"},
          "criteria_fit": {"type": "string"},
          "key_bets": {"type": "array", "items": {"type": "string"}},
          "key_risks": {"type": "array", "items": {"type": "string"}},
          "what_must_be_true": {"type": "array", "items": {"type": "string"}},
          "recommended": {"type": "boolean"}
        }
      }
    },
    "decision_refs": {"type": "array", "items": {"type": "string"}},
    "risk_refs": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
