{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Offer",
  "type": "object",
  "required": [
    "offer_id",
    "company_id",
    "name",
    "core_promise",
    "mechanism",
    "proof_points",
    "status",
    "confidence",
    "source_origin",
    "evidence_refs",
    "source_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "offer_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "company_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "service_id": {"type": "string"},
    "name": {"type": "string"},
    "core_promise": {"type": "string"},
    "mechanism": {"type": "string"},
    "proof_points": {"type": "array", "items": {"type": "string"}},
    "anti_claims": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["draft", "inferred", "needs_validation", "validated", "confirmed", "stale", "rejected"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_origin": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
